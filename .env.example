# Configuração para upload em Usenet com UpaPasta (nyuu ou pesto)
# Edite este arquivo para ajustar qualquer opção.
# Para configurar rapidamente, copie para ~/.config/upapasta/.env e preencha os valores obrigatórios.
# Na primeira execução o UpaPasta solicita as credenciais interativamente e gera este arquivo automaticamente.

# *** Server Options (Servidor Primário) ***
# Servidor NNTP do seu provedor (ex: news.eweka.nl, news.usenetexpress.com)
NNTP_HOST=news.example.com

# Porta NNTP (119 = sem criptografia, 443/563 = TLS/SSL)
NNTP_PORT=563

# Usar SSL/TLS (true/false)
NNTP_SSL=true

# Ignorar erro de certificado SSL (true/false) — use apenas se necessário
NNTP_IGNORE_CERT=false

# Usuário NNTP fornecido pelo seu provedor
NNTP_USER=seu_usuario

# Senha NNTP
NNTP_PASS=sua_senha

# Número de conexões simultâneas (verifique o limite do seu plano)
NNTP_CONNECTIONS=50

# *** Servidores secundários (failover) — opcional ***
# Se NNTP_HOST_2 estiver configurado, será tentado automaticamente em caso de falha do primário.
# Campos não definidos herdam do servidor primário (NNTP_USER, NNTP_PASS, NNTP_PORT, NNTP_SSL).
# Adicione NNTP_HOST_3, NNTP_HOST_4 ... NNTP_HOST_9 para mais servidores de failover.
# NNTP_HOST_2=
# NNTP_PORT_2=563
# NNTP_SSL_2=true
# NNTP_USER_2=
# NNTP_PASS_2=
# NNTP_CONNECTIONS_2=50

# *** Article Options ***
# Grupo Usenet para upload (pode ser uma única string ou uma lista separada por vírgula para pool aleatório)
USENET_GROUP=alt.binaries.boneless

# Tamanho máximo de cada artigo (700K é o padrão mais compatível)
ARTICLE_SIZE=700K

# *** Check Options (Verificação pós-upload - apenas para nyuu) ***
# Conexões usadas para verificar se os posts chegaram ao servidor
CHECK_CONNECTIONS=5

# Quantas vezes tentar verificar cada artigo
CHECK_TRIES=2

# Intervalo entre tentativas de verificação (ex: 5s, 30s)
CHECK_DELAY=5s

# Delay antes de um retry de verificação após falha
CHECK_RETRY_DELAY=30s

# Tentativas de verificação por post
CHECK_POST_TRIES=2

# *** NZB Options ***
# Caminho de saída do arquivo .nzb ({filename} = nome do arquivo enviado)
NZB_OUT={filename}.nzb

# Pasta específica para salvar os arquivos .nzb (se definido, ignora o diretório de NZB_OUT)
# NZB_OUT_DIR=/home/user/nzbs

# Comportamento quando .nzb já existe: rename (renomeia o novo), overwrite (sobrescreve), fail (aborta)
# NZB_CONFLICT=rename

# Sobrescrever .nzb existente com mesmo nome (true/false) - legado, prefira usar NZB_CONFLICT
NZB_OVERWRITE=true

# *** Compression Options ***
# Compressor padrão (rar ou 7z) quando a compactação é necessária (ex: ao usar --compress)
DEFAULT_COMPRESSOR=rar

# *** Other Options ***
# Ignorar erros de upload (all = ignora tudo, none = aborta ao primeiro erro)
SKIP_ERRORS=all

# Pasta para salvar posts que falharam (deixe vazio para desativar)
DUMP_FAILED_POSTS=

# Args extras repassados ao nyuu (ex: --article-threads=8 --queue=20)
NYUU_EXTRA_ARGS=

# Args extras repassados ao pesto (ex: --rate=20M --verify)
PESTO_EXTRA_ARGS=

# Script ou comando executado após cada upload bem-sucedido.
# Recebe variáveis via ambiente: UPAPASTA_NZB, UPAPASTA_NFO, UPAPASTA_ORIGINAL, UPAPASTA_SIZE, UPAPASTA_GROUP.
# POST_UPLOAD_SCRIPT=/path/to/script.sh

# Modo silencioso: suprime saída detalhada do nyuu ou pesto (true/false)
QUIET=false

# *** UI Options ***
# Exibir timestamp nos logs (true/false)
LOG_TIME=true

# *** Webhook Notifications ***
# URL para notificação pós-upload (Discord, Slack, Telegram ou genérico).
# Discord:  https://discord.com/api/webhooks/<id>/<token>
# Slack:    https://hooks.slack.com/services/<T>/<B>/<token>
# Telegram: https://api.telegram.org/bot<token>/sendMessage?chat_id=<id>
WEBHOOK_URL=

# *** TMDb Metadata (opcional) ***
# Chave da API do TMDb (obtenha em https://www.themoviedb.org/settings/api)
# Se preenchido, o UpaPasta busca sinopse e poster para o .nfo automaticamente.
TMDB_API_KEY=

# Idioma da busca (padrão: pt-BR)
TMDB_LANGUAGE=pt-BR

# Se true, aborta a busca se não houver correspondência exata no TMDb
TMDB_STRICT=true

# *** NFO Template (opcional) ***
# Caminho para um arquivo .txt com placeholders (ex: {{title}}, {{synopsis}}, {{year}}, {{poster}})
# NFO_TEMPLATE=/home/user/templates/movie.txt

# Banner ASCII ou texto fixo para o topo do NFO gerado automaticamente (quando não usa template)
# NFO_BANNER=UpaPasta Uploader

# *** Indexer Search — Newznab / Prowlarr (opcional) ***
#
# Permite buscar conteúdo no indexador antes de fazer upload.
# Se encontrado, baixa apenas o .nzb como backup e pula o upload.
#
# URL base da API Newznab do indexador (ex: Prowlarr local: http://localhost:9696/prowlarr/api/v1/newznab)
INDEXER_URL=

# Chave de API do indexador
INDEXER_APIKEY=

# Intervalo mínimo entre requisições ao indexador (segundos) — evita rate limit
INDEXER_RATE_SECS=2

# Validade do cache de buscas no indexador (dias) — evita re-consultar o mesmo item
INDEXER_CACHE_DAYS=30

# Diretório(s) onde procurar por backups externos e onde a TUI salva NZBs baixados do indexador.
# Itens com .nzb correspondente aqui aparecem como 🌐 externo na interface.
# Aceita múltiplos caminhos separados por vírgula.
EXTERNAL_NZB_DIR=
