# Configuração para upload em Usenet com nyuu
# Edite este arquivo para ajustar qualquer opção.
# Para configurar rapidamente, copie para ~/.config/upapasta/.env e preencha os valores obrigatórios.
# Na primeira execução o UpaPasta solicita as credenciais interativamente e gera este arquivo automaticamente.

# *** Server Options ***
# Servidor NNTP do seu provedor (ex: news.eweka.nl, news.usenetexpress.com)
NNTP_HOST=news.example.com

# Porta NNTP (119 = sem criptografia, 443/563 = TLS/SSL)
NNTP_PORT=563

# Usar SSL/TLS (true/false)
NNTP_SSL=true

# Ignorar erro de certificado SSL (true/false) — use apenas se necessário
NNTP_IGNORE_CERT=false

# Usuário NNTP fornecido pelo seu provedor
NNTP_USER=seu_usuario

# Senha NNTP
NNTP_PASS=sua_senha

# Número de conexões simultâneas (verifique o limite do seu plano)
NNTP_CONNECTIONS=50

# *** Servidor secundário (failover) — opcional ***
# Se NNTP_HOST_2 estiver configurado, será tentado automaticamente em caso de falha do primário.
# Campos não definidos herdam do servidor primário (NNTP_USER, NNTP_PASS, NNTP_PORT, NNTP_SSL).
# Adicione NNTP_HOST_3, NNTP_HOST_4 ... NNTP_HOST_9 para mais servidores de failover.
NNTP_HOST_2=
NNTP_PORT_2=563
NNTP_SSL_2=true
NNTP_USER_2=
NNTP_PASS_2=
NNTP_CONNECTIONS_2=50

# *** Article Options ***
# Grupo Usenet para upload (alt.binaries.boneless é amplamente retido)
USENET_GROUP=alt.binaries.boneless

# Tamanho máximo de cada artigo (700K é o padrão mais compatível)
ARTICLE_SIZE=700K

# *** Check Options ***
# Conexões usadas para verificar se os posts chegaram ao servidor
CHECK_CONNECTIONS=5

# Quantas vezes tentar verificar cada artigo
CHECK_TRIES=2

# Intervalo entre tentativas de verificação (ex: 5s, 30s)
CHECK_DELAY=5s

# Delay antes de um retry de verificação após falha
CHECK_RETRY_DELAY=30s

# Tentativas de verificação por post
CHECK_POST_TRIES=2

# *** NZB Options ***
# Caminho de saída do arquivo .nzb ({filename} = nome do arquivo enviado)
NZB_OUT={filename}.nzb

# Sobrescrever .nzb existente com mesmo nome (true/false)
NZB_OVERWRITE=true

# *** Other Options ***
# Ignorar erros de upload (all = ignora tudo, none = aborta ao primeiro erro)
SKIP_ERRORS=all

# Pasta para salvar posts que falharam (deixe vazio para desativar)
DUMP_FAILED_POSTS=

# Args extras repassados ao nyuu (ex: --article-threads=8 --queue=20)
NYUU_EXTRA_ARGS=

# Modo silencioso: suprime saída do nyuu (true/false)
QUIET=false

# *** UI Options ***
# Exibir timestamp nos logs (true/false)
LOG_TIME=true


# *** Webhook Notifications ***
# URL para notificação pós-upload (Discord, Slack, Telegram ou genérico).
# Discord:  https://discord.com/api/webhooks/<id>/<token>
# Slack:    https://hooks.slack.com/services/<T>/<B>/<token>
# Telegram: https://api.telegram.org/bot<token>/sendMessage?chat_id=<id>
# Genérico: qualquer URL que aceite POST JSON
WEBHOOK_URL=

# *** TMDb Metadata (opcional) ***
# Chave da API do TMDb (obtenha em https://www.themoviedb.org/settings/api)
# Se preenchido, o UpaPasta busca sinopse e poster para o .nfo automaticamente.
TMDB_API_KEY=

# Idioma da busca (padrão: pt-BR)
TMDB_LANGUAGE=pt-BR
